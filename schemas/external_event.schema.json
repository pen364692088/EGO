{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openemotion.org/schemas/external_event.schema.json",
  "title": "External Event",
  "description": "Schema for external events submitted via POST /events/external",
  "type": "object",
  "required": ["type", "target_id"],
  "properties": {
    "event_id": {
      "type": "string",
      "description": "Optional unique identifier for idempotency. Duplicate event_ids within 24h are deduplicated.",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "type": {
      "type": "string",
      "description": "Event type determining payload structure",
      "enum": ["user_message", "assistant_reply", "world_event"]
    },
    "target_id": {
      "type": "string",
      "description": "Target identifier for anti-forgery. Must match the authenticated context.",
      "minLength": 1,
      "maxLength": 256
    },
    "actor": {
      "type": "string",
      "description": "Actor identifier (defaults to target_id if not provided)",
      "minLength": 1,
      "maxLength": 256
    },
    "text": {
      "type": ["string", "null"],
      "description": "Event text content",
      "maxLength": 10000
    },
    "payload": {
      "type": "object",
      "description": "Type-specific payload data"
    },
    "meta": {
      "type": "object",
      "description": "Additional metadata",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "type": { "const": "user_message" } }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "properties": {
              "sentiment": {
                "type": "string",
                "enum": ["positive", "negative", "neutral"]
              },
              "urgency": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "entities": {
                "type": "array",
                "items": { "type": "string" },
                "maxItems": 100
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "assistant_reply" } }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "properties": {
              "tone": {
                "type": "string",
                "enum": ["soft", "warm", "guarded", "cold", "neutral"]
              },
              "intent": {
                "type": "string",
                "enum": ["repair", "distance", "seek", "set_boundary", "retaliate", "inform"]
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "world_event" } }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "properties": {
              "subtype": {
                "type": "string",
                "enum": ["care", "apology", "ignored", "rejection", "betrayal", "neutral", "uncertain", "repair_success", "time_passed"]
              },
              "severity": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "context": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "required": ["subtype"]
          }
        }
      }
    }
  ]
}
