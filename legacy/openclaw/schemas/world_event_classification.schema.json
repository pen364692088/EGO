{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openemotion.local/schemas/world_event_classification.schema.json",
  "title": "OpenEmotion World Event Classification",
  "type": "object",
  "additionalProperties": false,
  "required": ["subtype", "confidence", "evidence", "is_high_impact", "should_send", "fallback"],
  "properties": {
    "subtype": {
      "type": "string",
      "description": "Chosen semantic subtype for world_event.",
      "enum": ["care", "apology", "ignored", "rejection", "betrayal", "neutral", "uncertain"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 0,
      "maxItems": 2,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 160
      }
    },
    "is_high_impact": {
      "type": "boolean",
      "description": "High-impact events can strongly affect state; require higher confidence to send."
    },
    "should_send": {
      "type": "boolean",
      "description": "Whether to actually send world_event(subtype) to emotiond."
    },
    "fallback": {
      "type": "string",
      "description": "If should_send=false, what to do instead.",
      "enum": ["no_event_reply_observe", "ask_clarifying_question", "send_neutral_only"]
    },
    "notes": {
      "type": "string",
      "maxLength": 240,
      "description": "Optional short note for logging/debug; keep it short."
    }
  }
}
