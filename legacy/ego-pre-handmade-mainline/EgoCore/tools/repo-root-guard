#!/usr/bin/env python3
"""
Repo Root Guard v1.0 for EgoCore

Purpose:
  Validate and enforce canonical repo root before application startup.
  MUST be called at the EARLIEST stage of main().

Usage:
  repo-root-guard --check
  repo-root-guard --json

Exit Codes:
  0 - Current repo is canonical
  2 - Wrong repo, BLOCKED

Enforcement: MANDATORY for EgoCore
"""

import argparse
import json
import os
import subprocess
import sys
from pathlib import Path
from datetime import datetime
from typing import Optional, Dict, Any, List
from dataclasses import dataclass
from enum import Enum
import yaml

# Ensure os is available for path operations


class RepoStatus(Enum):
    CANONICAL = "canonical"
    WRONG_REPO = "wrong_repo"
    BLOCKED = "blocked"
    AMBIGUOUS = "ambiguous"
    ERROR = "error"


@dataclass
class ValidationResult:
    status: RepoStatus
    current_dir: str
    canonical_root: Optional[str]
    repo_name: Optional[str]
    can_auto_switch: bool
    message: str
    blocked_operations: List[str]
    
    def to_dict(self) -> dict:
        return {
            "status": self.status.value,
            "current_dir": self.current_dir,
            "canonical_root": self.canonical_root,
            "repo_name": self.repo_name,
            "can_auto_switch": self.can_auto_switch,
            "message": self.message,
            "blocked_operations": self.blocked_operations
        }


class CanonicalRepoRegistry:
    """Load and resolve canonical repo definitions"""
    
    def __init__(self, registry_path: Optional[str] = None):
        if registry_path is None:
            # Try to find config relative to this script
            script_dir = Path(__file__).parent
            registry_path = script_dir.parent / "config" / "canonical_repos.yaml"
        
        self.registry_path = Path(registry_path)
        self.registry = self._load_registry()
    
    def _load_registry(self) -> dict:
        """Load registry from YAML file"""
        if not self.registry_path.exists():
            return {"canonical_repos": {}}
        
        with open(self.registry_path, 'r') as f:
            return yaml.safe_load(f) or {"canonical_repos": {}}
    
    def get_repo(self, repo_name: str) -> Optional[dict]:
        """Get canonical repo definition"""
        return self.registry.get("canonical_repos", {}).get(repo_name)
    
    def get_all_canonical_roots(self) -> Dict[str, str]:
        """Get all canonical roots"""
        roots = {}
        for repo_name, repo_def in self.registry.get("canonical_repos", {}).items():
            root = repo_def.get("canonical_root")
            if root:
                roots[repo_name] = root
        return roots
    
    def get_default_repo(self) -> Optional[str]:
        """Get the first/default repo name"""
        repos = list(self.registry.get("canonical_repos", {}).keys())
        return repos[0] if repos else None


class RepoRootGuard:
    """
    Repo Root Guard for EgoCore
    
    Validates and enforces canonical repo root before application startup.
    """
    
    def __init__(self, registry_path: Optional[str] = None, repo_name: str = "EgoCore"):
        self.registry = CanonicalRepoRegistry(registry_path)
        self.repo_name = repo_name
    
    def check(self) -> ValidationResult:
        """Check if current directory is the canonical repo"""
        current_dir = os.getcwd()
        
        # Get canonical root for this project
        repo_def = self.registry.get_repo(self.repo_name)
        
        if not repo_def:
            return ValidationResult(
                status=RepoStatus.ERROR,
                current_dir=current_dir,
                canonical_root=None,
                repo_name=self.repo_name,
                can_auto_switch=False,
                message=f"⚠️ Repo definition not found for {self.repo_name}",
                blocked_operations=[]
            )
        
        canonical_root = repo_def.get("canonical_root")
        
        if not canonical_root:
            return ValidationResult(
                status=RepoStatus.ERROR,
                current_dir=current_dir,
                canonical_root=None,
                repo_name=self.repo_name,
                can_auto_switch=False,
                message=f"⚠️ Canonical root not defined for {self.repo_name}",
                blocked_operations=[]
            )
        
        # Normalize paths for cross-platform comparison
        current_dir_norm = os.path.normpath(current_dir)
        canonical_root_norm = os.path.normpath(canonical_root)

        # Check if current directory matches canonical root
        if current_dir_norm == canonical_root_norm or current_dir_norm.startswith(canonical_root_norm + os.sep):
            return ValidationResult(
                status=RepoStatus.CANONICAL,
                current_dir=current_dir,
                canonical_root=canonical_root,
                repo_name=self.repo_name,
                can_auto_switch=False,
                message=f"✅ Current directory is canonical repo: {self.repo_name}",
                blocked_operations=[]
            )
        
        # Not in canonical repo - check if in forbidden alternative
        forbidden = repo_def.get("forbidden_alternatives", [])
        reason = ""
        
        for fb in forbidden:
            fb_path = fb.get("path", "")
            if current_dir == fb_path or current_dir.startswith(fb_path + "/"):
                reason = fb.get("reason", "")
                break
        
        enforcement = repo_def.get("enforcement", {})
        
        return ValidationResult(
            status=RepoStatus.WRONG_REPO,
            current_dir=current_dir,
            canonical_root=canonical_root,
            repo_name=self.repo_name,
            can_auto_switch=enforcement.get("auto_switch_allowed", False),
            message=self._format_block_message(self.repo_name, canonical_root, current_dir, reason),
            blocked_operations=enforcement.get("blocked_operations", ["application_startup"])
        )
    
    def _format_block_message(self, repo_name: str, canonical_root: str, current_dir: str, reason: str) -> str:
        """Format blocking message"""
        msg = f"""🚫 REPO ROOT MISMATCH

Expected Canonical Root: {canonical_root}
Current Directory: {current_dir}
Repo: {repo_name}
"""
        if reason:
            msg += f"Reason: {reason}\n"
        
        msg += f"""
You are NOT in the correct repository for EgoCore.

EgoCore must be run from its canonical repository root.

Action Required:
1. cd {canonical_root}
2. python -m app.main --telegram

Until resolved:
- Application startup BLOCKED
"""
        return msg


def check_repo_root(repo_name: str = "EgoCore", registry_path: Optional[str] = None) -> ValidationResult:
    """
    Convenience function to check repo root.
    
    Args:
        repo_name: Project name (default: EgoCore)
        registry_path: Path to canonical_repos.yaml
    
    Returns:
        ValidationResult
    """
    guard = RepoRootGuard(registry_path=registry_path, repo_name=repo_name)
    return guard.check()


def enforce_repo_root(repo_name: str = "EgoCore", registry_path: Optional[str] = None) -> None:
    """
    Enforce repo root, exit if wrong.
    
    Args:
        repo_name: Project name (default: EgoCore)
        registry_path: Path to canonical_repos.yaml
    
    Raises:
        SystemExit: If not in canonical repo
    """
    result = check_repo_root(repo_name=repo_name, registry_path=registry_path)
    
    if result.status != RepoStatus.CANONICAL:
        print(result.message, file=sys.stderr)
        sys.exit(2)


# =============================================================================
# CLI Interface
# =============================================================================

def main():
    """CLI interface for repo-root-guard"""
    parser = argparse.ArgumentParser(description="Repo Root Guard v1.0 for EgoCore")
    parser.add_argument("--check", action="store_true", help="Check current repo status")
    parser.add_argument("--repo", default="EgoCore", help="Target repo name")
    parser.add_argument("--json", action="store_true", help="Output as JSON")
    parser.add_argument("--registry", help="Custom registry path")
    
    args = parser.parse_args()
    
    guard = RepoRootGuard(registry_path=args.registry, repo_name=args.repo)
    result = guard.check()
    
    if args.json:
        print(json.dumps(result.to_dict(), indent=2))
    else:
        print(result.message)
    
    # Exit codes
    if result.status == RepoStatus.CANONICAL:
        return 0
    else:
        return 2


if __name__ == "__main__":
    sys.exit(main())
