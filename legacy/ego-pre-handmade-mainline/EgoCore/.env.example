# Application
APP_NAME=openemotion-agent-runtime
APP_ENV=development
LOG_LEVEL=INFO

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_CHAT_IDS=
