{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "event_input.schema.json",
  "title": "Event Input Contract",
  "description": "EgoCore → OpenEmotion 标准事件契约。定义 EgoCore 向 OpenEmotion 传递事件的结构化格式。",
  "schema_version": "1.0.0",
  "schema_version_policy": {
    "major": "破坏性变更：必填字段移除/重命名、类型变更",
    "minor": "向后兼容：新增可选字段、扩展枚举值",
    "patch": "文档/描述修正"
  },
  "type": "object",
  "required": [
    "schema_version",
    "event_id",
    "timestamp",
    "actor",
    "source",
    "event_type",
    "user_intent",
    "safety_context"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "契约版本号 (semver)",
      "default": "1.0.0"
    },
    "event_id": {
      "type": "string",
      "description": "事件唯一标识符",
      "pattern": "^evt_[a-zA-Z0-9_-]+$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "事件发生时间 (ISO 8601)"
    },
    "actor": {
      "type": "object",
      "description": "事件发起者信息",
      "required": ["actor_id", "actor_type"],
      "properties": {
        "actor_id": {
          "type": "string",
          "description": "发起者唯一标识"
        },
        "actor_type": {
          "type": "string",
          "enum": ["user", "system", "agent", "external_service"],
          "description": "发起者类型"
        },
        "display_name": {
          "type": "string",
          "description": "显示名称"
        },
        "metadata": {
          "type": "object",
          "description": "额外元数据"
        }
      }
    },
    "source": {
      "type": "object",
      "description": "事件来源",
      "required": ["channel", "surface"],
      "properties": {
        "channel": {
          "type": "string",
          "enum": ["telegram", "discord", "slack", "web", "cli", "api", "internal"],
          "description": "通信渠道"
        },
        "surface": {
          "type": "string",
          "description": "具体界面/平台"
        },
        "session_id": {
          "type": "string",
          "description": "会话标识"
        },
        "message_id": {
          "type": "string",
          "description": "消息标识"
        }
      }
    },
    "event_type": {
      "type": "string",
      "enum": [
        "user_message",
        "user_command",
        "task_started",
        "task_completed",
        "task_failed",
        "tool_invoked",
        "tool_result",
        "state_change",
        "external_event",
        "system_notification"
      ],
      "description": "事件类型"
    },
    "user_intent": {
      "type": "object",
      "description": "解析后的用户意图",
      "required": ["primary_intent"],
      "properties": {
        "primary_intent": {
          "type": "string",
          "description": "主要意图分类"
        },
        "secondary_intents": {
          "type": "array",
          "items": { "type": "string" },
          "description": "次要意图"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "意图识别置信度"
        },
        "raw_input": {
          "type": "string",
          "description": "原始用户输入"
        }
      }
    },
    "task_context": {
      "type": "object",
      "description": "任务上下文",
      "properties": {
        "task_id": {
          "type": "string",
          "description": "当前任务 ID"
        },
        "task_status": {
          "type": "string",
          "enum": ["pending", "running", "blocked", "completed", "failed"],
          "description": "任务状态"
        },
        "step_id": {
          "type": "string",
          "description": "当前步骤 ID"
        },
        "parent_task_id": {
          "type": "string",
          "description": "父任务 ID（如果有）"
        },
        "task_goal": {
          "type": "string",
          "description": "任务目标描述"
        }
      }
    },
    "conversation_context": {
      "type": "object",
      "description": "对话上下文",
      "properties": {
        "turn_number": {
          "type": "integer",
          "minimum": 0,
          "description": "当前轮次"
        },
        "recent_exchanges": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "assistant", "system"] },
              "content": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          },
          "description": "最近几轮对话"
        },
        "topic_summary": {
          "type": "string",
          "description": "话题摘要"
        }
      }
    },
    "runtime_summary": {
      "type": "object",
      "description": "运行时状态摘要",
      "properties": {
        "model_in_use": {
          "type": "string",
          "description": "当前使用的模型"
        },
        "session_duration_sec": {
          "type": "number",
          "description": "会话持续时间（秒）"
        },
        "tokens_used": {
          "type": "integer",
          "description": "已用 token 数"
        },
        "tools_available": {
          "type": "array",
          "items": { "type": "string" },
          "description": "可用工具列表"
        }
      }
    },
    "safety_context": {
      "type": "object",
      "description": "安全上下文",
      "required": ["risk_level"],
      "properties": {
        "risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "description": "风险评估等级"
        },
        "flags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "安全标记"
        },
        "gate_status": {
          "type": "object",
          "properties": {
            "gate_a": { "type": "string", "enum": ["passed", "pending", "failed", "skipped"] },
            "gate_b": { "type": "string", "enum": ["passed", "pending", "failed", "skipped"] },
            "gate_c": { "type": "string", "enum": ["passed", "pending", "failed", "skipped"] }
          }
        },
        "constraints_applied": {
          "type": "array",
          "items": { "type": "string" },
          "description": "已应用的约束"
        }
      }
    },
    "external_result": {
      "type": "object",
      "description": "外部操作结果（如果有）",
      "properties": {
        "operation_type": {
          "type": "string",
          "description": "操作类型"
        },
        "success": {
          "type": "boolean",
          "description": "是否成功"
        },
        "result_summary": {
          "type": "string",
          "description": "结果摘要"
        },
        "error": {
          "type": "object",
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "扩展元数据",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
