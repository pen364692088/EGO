{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "restore_audit.schema.json",
  "title": "Restore Audit Contract",
  "description": "自我恢复审计记录",
  "schema_version": "1.0.0",
  "type": "object",
  "required": [
    "schema_version",
    "restore_id",
    "timestamp",
    "session_id",
    "status",
    "loaded_layers",
    "duration_ms"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "default": "1.0.0"
    },
    "restore_id": {
      "type": "string",
      "description": "恢复唯一标识"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "恢复时间"
    },
    "session_id": {
      "type": "string",
      "description": "会话标识"
    },
    "status": {
      "type": "string",
      "enum": ["success", "partial", "failed"],
      "description": "恢复状态"
    },
    "loaded_layers": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["identity", "self_model", "summary"]
      },
      "description": "成功加载的层"
    },
    "identity_ref": {
      "type": "object",
      "properties": {
        "identity_handle": { "type": "string" },
        "file_path": { "type": "string" },
        "loaded_at": { "type": "string", "format": "date-time" }
      }
    },
    "self_model_ref": {
      "type": "object",
      "properties": {
        "model_handle": { "type": "string" },
        "file_path": { "type": "string" },
        "loaded_at": { "type": "string", "format": "date-time" }
      }
    },
    "summary_ref": {
      "type": "object",
      "properties": {
        "summary_id": { "type": "string" },
        "file_path": { "type": "string" },
        "loaded_at": { "type": "string", "format": "date-time" }
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "level", "description"],
        "properties": {
          "type": { "type": "string" },
          "level": { "type": "string", "enum": ["error", "warning", "info"] },
          "description": { "type": "string" },
          "resolution": { "type": "string" }
        }
      },
      "description": "冲突列表"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "警告列表"
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "错误列表"
    },
    "injected_context": {
      "type": "object",
      "properties": {
        "identity_loaded": { "type": "boolean" },
        "capabilities_count": { "type": "integer" },
        "limitations_count": { "type": "integer" },
        "active_goals_count": { "type": "integer" },
        "recovery_hints_present": { "type": "boolean" }
      },
      "description": "注入上下文摘要"
    },
    "duration_ms": {
      "type": "number",
      "description": "恢复耗时（毫秒）"
    },
    "degraded_mode": {
      "type": "boolean",
      "default": false,
      "description": "是否降级模式"
    },
    "degradation_reason": {
      "type": "string",
      "description": "降级原因"
    }
  }
}
