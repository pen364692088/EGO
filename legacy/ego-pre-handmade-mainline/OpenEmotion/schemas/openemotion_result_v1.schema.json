{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openemotion.org/schemas/openemotion_result_v1.schema.json",
  "title": "OpenEmotion Result v1",
  "description": "正式输出 schema - OpenEmotion → EgoCore",
  "type": "object",
  "required": ["event_id", "result_type", "confidence"],
  "additionalProperties": true,
  "properties": {
    "event_id": {
      "type": "string",
      "description": "对应输入事件ID",
      "minLength": 1,
      "maxLength": 128
    },
    "result_type": {
      "type": "string",
      "description": "结果类型",
      "enum": ["interpretation", "memory_update", "policy_change", "error"]
    },
    "identity_state_delta": {
      "type": "object",
      "description": "身份状态变化"
    },
    "self_model_delta": {
      "type": "object",
      "description": "自我模型变化",
      "properties": {
        "field": {
          "type": "string",
          "description": "变化字段"
        },
        "old_value": {
          "description": "旧值"
        },
        "new_value": {
          "description": "新值"
        },
        "reason": {
          "type": "string",
          "description": "变化原因"
        }
      }
    },
    "memory_update": {
      "type": "object",
      "description": "记忆更新",
      "properties": {
        "event_stored": {
          "type": "boolean",
          "description": "事件是否存储"
        },
        "narrative_created": {
          "type": "boolean",
          "description": "是否创建叙事"
        },
        "policy_candidate": {
          "type": "boolean",
          "description": "是否产生策略候选"
        },
        "salience_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "重要性分数"
        }
      }
    },
    "relationship_update": {
      "type": "object",
      "description": "关系更新"
    },
    "appraisal_state_delta": {
      "type": "object",
      "description": "评估状态变化",
      "properties": {
        "trust": {"type": "number"},
        "caution": {"type": "number"},
        "frustration": {"type": "number"},
        "joy": {"type": "number"},
        "sadness": {"type": "number"},
        "anger": {"type": "number"}
      }
    },
    "reflection_note": {
      "type": ["object", "null"],
      "description": "反思笔记"
    },
    "policy_hint": {
      "type": "object",
      "description": "策略提示（给 EgoCore 参考）",
      "properties": {
        "hint_type": {
          "type": "string",
          "enum": ["prefer", "avoid", "escalate", "defer", "ignore"],
          "description": "提示类型"
        },
        "reason": {
          "type": "string",
          "description": "提示原因"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "提示置信度"
        }
      }
    },
    "response_tendency": {
      "type": "object",
      "description": "响应倾向",
      "properties": {
        "tone": {
          "type": "string",
          "enum": ["calm", "warm", "guarded", "neutral"]
        },
        "urgency": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "should_acknowledge_context": {"type": "boolean"},
        "should_invite_next_step": {"type": "boolean"}
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "整体置信度"
    },
    "stability_metadata": {
      "type": "object",
      "description": "稳定性元数据",
      "properties": {
        "state_ok": {"type": "boolean"},
        "degraded": {"type": "boolean"},
        "degradation_reason": {"type": "string"}
      }
    }
  }
}
