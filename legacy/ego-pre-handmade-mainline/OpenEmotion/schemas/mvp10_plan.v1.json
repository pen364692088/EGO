{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openemotion.org/schemas/mvp10_plan.v1.json",
  "title": "MVP10 Plan",
  "description": "Schema for structured plans in LucidLoop MVP-10",
  "type": "object",
  "required": ["plan"],
  "properties": {
    "plan": {
      "type": "object",
      "required": ["steps", "risk_level", "expected_outcome"],
      "properties": {
        "plan_id": {
          "type": "string",
          "description": "Unique identifier for this plan"
        },
        "goal": {
          "type": "string",
          "description": "What this plan aims to achieve"
        },
        "steps": {
          "type": "array",
          "description": "Ordered list of steps to execute",
          "items": {
            "type": "object",
            "required": ["action"],
            "properties": {
              "step_id": {"type": "string"},
              "action": {"type": "string"},
              "params": {"type": "object"},
              "expected_result": {"type": "string"},
              "rollback": {"type": "string"},
              "required_evidence": {
                "type": "array",
                "items": {"type": "string"},
                "description": "Evidence required before proceeding"
              }
            }
          }
        },
        "risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "description": "Overall risk assessment of the plan"
        },
        "expected_outcome": {
          "type": "string",
          "description": "What we expect to happen if plan succeeds"
        },
        "rollback": {
          "type": "string",
          "description": "What to do if plan fails"
        },
        "required_evidence": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Evidence required before plan can be executed"
        },
        "constraints": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Constraints that must be respected"
        },
        "timeout_seconds": {
          "type": "integer",
          "description": "Maximum time for plan execution"
        },
        "created_at": {
          "type": "number",
          "description": "Unix timestamp when plan was created"
        }
      }
    }
  }
}
