      "case_id": "case_1",
      "case_name": "同义改写命中 - 深色主题偏好",
      "category": "synonym_rewrite",
      "objective": "同义表达应命中正确 narrative",
      "events": [
        {
          "id": "event_1_1",
          "user_id": "test_user_alpha",
          "event_type": "preference_update",
          "payload": {"content": "I prefer dark mode for coding in the evening", "category": "ui"}
        },
        {
          "id": "event_1_2",
          "user_id": "test_user_alpha",
          "event_type": "preference_update",
          "payload": {"content": "I like using dark theme when programming at night", "category": "ui"}
        }
      ],
      "query": "What are my coding theme preferences?",
      "expected": {"narrative_hit": true, "min_similarity": 0.3}
    },
    
    {
      "case_id": "case_2",
      "case_name": "同义改写命中 - 早晨工作偏好",
