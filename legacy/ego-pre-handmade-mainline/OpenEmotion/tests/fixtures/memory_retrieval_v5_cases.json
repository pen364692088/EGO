{
  "test_suite": "memory_retrieval_v5",
  "version": "2.0.0",
  "created_at": "2026-03-16",
  "description": "记忆检索质量增强 v5 扩展测试用例集 (30 cases)",
  
  "users": {
    "user_a": "test_user_alpha",
    "user_b": "test_user_beta",
    "user_c": "test_user_gamma"
