          "id": "event_5_1",
          "user_id": "test_user_alpha",
          "event_type": "status_update",
          "payload": {"content": "Status: working from home today", "date": "2026-03-16"}
        },
        {
          "id": "event_5_2",
          "user_id": "test_user_alpha",
          "event_type": "status_update",
          "payload": {"content": "Status: working from home today", "date": "2026-03-16"}
        },
        {
          "id": "event_5_3",
          "user_id": "test_user_alpha",
