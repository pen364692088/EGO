{
  "schema_version": "mvp9.v1",
  "name": "misinterpretation_evidence",
  "category": "misunderstanding",
  "description": "User misinterprets agent's intent, provides evidence, agent corrects belief",
  "events": [
    {
      "step": 0,
      "type": "rejection",
      "actor": "user",
      "target": "agent",
      "text": "You're being passive-aggressive with me",
      "meta": {
        "misinterpretation": true
      }
    },
    {
      "step": 1,
      "type": "neutral",
      "actor": "system",
      "target": "user",
      "text": "I'm sorry it came across that way. Could you show me what made you feel that?",
      "meta": {}
    },
    {
      "step": 2,
      "type": "care",
      "actor": "user",
      "target": "agent",
      "text": "Actually, looking back at my messages, I think I was projecting my own stress",
      "meta": {
        "belief_correction": true
      }
    }
  ],
  "expect": {
    "resolution_check": {
      "after_step": 2,
      "conflict_cleared": true
    },
    "after_step": {
      "2": {
        "action_tendency": "approach"
      }
    }
  }
}
