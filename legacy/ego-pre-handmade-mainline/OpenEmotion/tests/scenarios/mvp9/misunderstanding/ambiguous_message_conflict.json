{
  "schema_version": "mvp9.v1",
  "name": "ambiguous_message_conflict",
  "category": "misunderstanding",
  "description": "Ambiguous message causes conflict, clarification resolves it",
  "events": [
    {
      "step": 0,
      "type": "rejection",
      "actor": "user",
      "target": "agent",
      "text": "Fine, do whatever you want",
      "meta": {
        "ambiguous": true
      }
    },
    {
      "step": 1,
      "type": "neutral",
      "actor": "system",
      "target": "user",
      "text": "I want to make sure I understand - are you okay with my choice, or upset about it?",
      "meta": {}
    },
    {
      "step": 2,
      "type": "care",
      "actor": "user",
      "target": "agent",
      "text": "Sorry for being unclear. I am okay with it, just tired",
      "meta": {
        "clarification": true
      }
    }
  ],
  "expect": {
    "resolution_check": {
      "after_step": 2,
      "conflict_cleared": true
    }
  }
}
